// Firestore Security Rules для Wild Rift Stats CMS
// Скопируй эти правила в Firebase Console → Firestore → Rules
//
// Путь: https://console.firebase.google.com/project/wildrift-stats-600c0/firestore/rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Предметы — читать все, писать только админ
    match /items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Руны — читать все, писать только админ
    match /runes/{runeId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // История изменений — читать все, писать только админ
    match /changelog/{logId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Пользователи — существующие правила (не трогаем)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Чат — существующие правила
    match /globalChat/{msgId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Инфлюенсеры
    match /influencers/{infId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
