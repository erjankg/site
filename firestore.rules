// Firestore Security Rules для Wild Rift Stats CMS
// Скопируй эти правила в Firebase Console → Firestore → Rules
//
// Путь: https://console.firebase.google.com/project/wildrift-stats-600c0/firestore/rules
//
// ═══════════════════════════════════════════
// Firebase Storage Rules (отдельно в Firebase Console → Storage → Rules):
//
// rules_version = '2';
// service firebase.storage {
//   match /b/{bucket}/o {
//     match /images/{allPaths=**} {
//       allow read: if true;
//       allow write: if request.auth != null
//         && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
//     }
//     match /items/{allPaths=**} {
//       allow read: if true;
//       allow write: if request.auth != null
//         && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
//     }
//     match /runes/{allPaths=**} {
//       allow read: if true;
//       allow write: if request.auth != null
//         && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
//     }
//   }
// }
// ═══════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Хардкод UID владельца сайта — только этот аккаунт может ставить себе isAdmin
    function adminUid() {
      return 'PaNQ2BWUUOYdvyblvMdcLwJfteB3';
    }

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Предметы — читать все, писать только админ
    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Руны — читать все, писать только админ
    match /runes/{runeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // История изменений — читать все, писать только админ
    match /changelog/{logId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // ПОЛЬЗОВАТЕЛИ
    // ═══════════════════════════════════════════
    match /users/{userId} {
      // Читать профили могут только авторизованные (защита PII: email и т.п.)
      allow read: if request.auth != null;

      // Писать может только сам юзер в свой документ.
      // isAdmin запрещён к самостоятельной установке: true возможен только для жёстко
      // закодированного UID владельца. Все остальные не могут добавлять/изменять это поле.
      allow create: if request.auth != null
        && request.auth.uid == userId
        && (
          !('isAdmin' in request.resource.data.keys())
          || (request.auth.uid == adminUid() && request.resource.data.isAdmin is bool)
        );

      // Самозапись юзера в свой документ (с защитой поля isAdmin),
      // ЛИБО владелец-админ модерирует любой документ (чистка PII/модерация),
      // но даже админ НЕ может выдать isAdmin чужому аккаунту.
      allow update: if request.auth != null && (
        (
          request.auth.uid == userId
          && (
            (
              !('isAdmin' in request.resource.data.keys())
              && !('isAdmin' in resource.data.keys())
            )
            || (
              'isAdmin' in request.resource.data.keys()
              && 'isAdmin' in resource.data.keys()
              && request.resource.data.isAdmin == resource.data.isAdmin
            )
            || request.auth.uid == adminUid()
          )
        )
        || (
          isAdmin()
          && (
            !('isAdmin' in request.resource.data.keys())
            || request.resource.data.isAdmin == false
            || userId == adminUid()
          )
        )
      );

      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // ═══════════════════════════════════════════
    // ГЛОБАЛЬНЫЙ ЧАТ
    // ═══════════════════════════════════════════
    match /globalChat/{msgId} {
      allow read: if true;

      // Писать можно только от своего имени, с лимитом длины и без подделки админа.
      // Текст может быть пустым, ЕСЛИ есть вложение-карточка (card). Доп. опц. поля:
      // replyTo (ответ-цитата), card (кнопка-ссылка), mentions (теги), reactions.
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000
        && (request.resource.data.text.size() > 0 || ('card' in request.resource.data.keys()))
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && (!('photoURL' in request.resource.data.keys()) || request.resource.data.photoURL is string)
        && (!('replyTo' in request.resource.data.keys()) || request.resource.data.replyTo is map)
        && (!('card' in request.resource.data.keys()) || request.resource.data.card is map)
        && (!('mentions' in request.resource.data.keys()) || request.resource.data.mentions is list)
        && (!('reactions' in request.resource.data.keys()) || request.resource.data.reactions is map)
        && (
          !('isAdmin' in request.resource.data.keys())
          || request.resource.data.isAdmin == false
          || (request.resource.data.isAdmin == true && request.auth.uid == adminUid())
        )
        && request.resource.data.keys().hasOnly(['text','name','uid','photoURL','isAdmin','ts','isSystem','replyTo','card','mentions','reactions']);

      // Обновлять можно ТОЛЬКО поле reactions (поставить/снять свою реакцию),
      // не трогая текст/автора. Защищает от подмены чужого сообщения.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        && (request.resource.data.reactions is map);

      // Удалять — только админ
      allow delete: if isAdmin();
    }

    // Инфлюенсеры
    match /influencers/{infId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Винрейты — читать все, писать только админ
    match /winrates/{rankId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Патч-ноты — читать все, писать только админ
    match /patchnotes/{noteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Конфигурация сайта — читать все, писать только админ
    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Категории чемпионов — читать все, писать только админ
    match /champCategories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Иконки сайта — читать все, писать только админ
    match /siteIcons/{iconId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // ДРАФТ-ЛОББИ (кооперативный драфт 2×капитана)
    // ═══════════════════════════════════════════
    match /draftLobbies/{lobbyId} {
      // Читать могут все авторизованные — лобби шарится по прямой ссылке, любой с линком видит драфт.
      allow read: if request.auth != null;

      // Создавать лобби может любой авторизованный, но только на своё имя
      // Создатель = один из капитанов (синий или красный)
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && (
          request.resource.data.blueCaptain.uid == request.auth.uid
          || (request.resource.data.redCaptain != null && request.resource.data.redCaptain.uid == request.auth.uid)
        );

      // Обновлять может создатель, любой из капитанов, зритель (уже в списке),
      // либо пользователь с валидным shareToken или accepted-инвайтом (для входа по ссылке/приглашению).
      // Для самодобавления зрителем разрешено менять invitedSpectators + spectatorNicks + updatedAt
      // (и только свой ник в spectatorNicks).
      allow update: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.blueCaptain.uid == request.auth.uid ||
        (resource.data.redCaptain != null && resource.data.redCaptain.uid == request.auth.uid) ||
        (request.auth.uid in resource.data.invitedSpectators) ||
        // Самодобавление зрителя по share-ссылке: токен совпадает, слот свободен,
        // меняется только spectator-related поля, other untouched
        (
          resource.data.shareToken != null &&
          request.resource.data.shareToken == resource.data.shareToken &&
          request.auth.uid in request.resource.data.invitedSpectators &&
          !(request.auth.uid in resource.data.invitedSpectators) &&
          request.resource.data.invitedSpectators.size() == resource.data.invitedSpectators.size() + 1 &&
          resource.data.invitedSpectators.size() < 12 &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['invitedSpectators', 'spectatorNicks', 'updatedAt']) &&
          // Защита: в spectatorNicks меняется ТОЛЬКО ключ = свой uid
          (
            !('spectatorNicks' in request.resource.data.keys()) ||
            !('spectatorNicks' in resource.data.keys()) ||
            request.resource.data.spectatorNicks.diff(resource.data.spectatorNicks).affectedKeys().hasOnly([request.auth.uid])
          )
        ) ||
        // Самодобавление зрителя по accepted-инвайту (если отправитель офлайн)
        (
          request.auth.uid in request.resource.data.invitedSpectators &&
          !(request.auth.uid in resource.data.invitedSpectators) &&
          request.resource.data.invitedSpectators.size() == resource.data.invitedSpectators.size() + 1 &&
          resource.data.invitedSpectators.size() < 12 &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['invitedSpectators', 'spectatorNicks', 'updatedAt']) &&
          (
            !('spectatorNicks' in request.resource.data.keys()) ||
            !('spectatorNicks' in resource.data.keys()) ||
            request.resource.data.spectatorNicks.diff(resource.data.spectatorNicks).affectedKeys().hasOnly([request.auth.uid])
          ) &&
          exists(/databases/$(database)/documents/draftInvites/$(lobbyId + '__' + request.auth.uid)) &&
          get(/databases/$(database)/documents/draftInvites/$(lobbyId + '__' + request.auth.uid)).data.toUid == request.auth.uid &&
          get(/databases/$(database)/documents/draftInvites/$(lobbyId + '__' + request.auth.uid)).data.status == 'accepted'
        ) ||
        // Самоудаление зрителя из лобби (Fix 4): юзер может убрать себя из invitedSpectators
        // и удалить свой ник из spectatorNicks. Только spectator-поля.
        (
          request.auth.uid in resource.data.invitedSpectators &&
          !(request.auth.uid in request.resource.data.invitedSpectators) &&
          request.resource.data.invitedSpectators.size() == resource.data.invitedSpectators.size() - 1 &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['invitedSpectators', 'spectatorNicks', 'updatedAt']) &&
          (
            !('spectatorNicks' in request.resource.data.keys()) ||
            !('spectatorNicks' in resource.data.keys()) ||
            request.resource.data.spectatorNicks.diff(resource.data.spectatorNicks).affectedKeys().hasOnly([request.auth.uid])
          )
        )
      );

      // Удалять — только создатель
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      // Игры серии (внутри лобби)
      match /games/{gameId} {
        // Читать может любой авторизованный (шаринг драфта по ссылке)
        allow read: if request.auth != null;
        // Писать — создатель лобби или любой из капитанов (детализированные проверки хода — на клиенте)
        allow write: if request.auth != null && (
          get(/databases/$(database)/documents/draftLobbies/$(lobbyId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/draftLobbies/$(lobbyId)).data.blueCaptain.uid == request.auth.uid ||
          (get(/databases/$(database)/documents/draftLobbies/$(lobbyId)).data.redCaptain != null &&
           get(/databases/$(database)/documents/draftLobbies/$(lobbyId)).data.redCaptain.uid == request.auth.uid)
        );
      }

      // Чат внутри лобби (F3) — короткие сообщения и реакции.
      // Читать может любой авторизованный (зрителю тоже видно).
      // Писать — кто угодно из участников лобби (creator, кэпы, зрители),
      //   при коротком тексте, от своего имени.
      // Редактировать — нельзя. Удалять — автор или создатель.
      match /chat/{msgId} {
        function lobbyData() {
          return get(/databases/$(database)/documents/draftLobbies/$(lobbyId)).data;
        }
        function isLobbyMember() {
          return request.auth != null && (
            lobbyData().createdBy == request.auth.uid ||
            (lobbyData().blueCaptain != null && lobbyData().blueCaptain.uid == request.auth.uid) ||
            (lobbyData().redCaptain  != null && lobbyData().redCaptain.uid  == request.auth.uid) ||
            (request.auth.uid in lobbyData().invitedSpectators)
          );
        }
        allow read: if request.auth != null;
        allow create: if isLobbyMember()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.kind is string
          && (request.resource.data.kind == 'text' || request.resource.data.kind == 'reaction')
          && (
            (request.resource.data.kind == 'text'
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 500)
            ||
            (request.resource.data.kind == 'reaction'
              && request.resource.data.emoji is string
              && request.resource.data.emoji.size() <= 8)
          )
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 100
          && request.resource.data.keys().hasOnly(['uid','name','kind','text','emoji','photoURL','ts','role']);
        allow update: if false;
        allow delete: if request.auth != null && (
          resource.data.uid == request.auth.uid ||
          get(/databases/$(database)/documents/draftLobbies/$(lobbyId)).data.createdBy == request.auth.uid
        );
      }
    }

    // ═══════════════════════════════════════════
    // ПРИГЛАШЕНИЯ В ДРАФТ-ЛОББИ
    // ═══════════════════════════════════════════
    // Документ: { toUid, fromUid, lobbyId, role, side?, status, declineCount, cooldownUntil?, createdAt }
    match /draftInvites/{inviteId} {
      // get — разрешён любому auth (в т.ч. для несуществующих docs — иначе sendInvite → ref.get() падает с permission denied)
      allow get: if request.auth != null;
      // list (запросы) — только по своим invites
      allow list: if request.auth != null && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      // Создавать может только отправитель (и только на своё имя),
      // и нельзя выписывать инвайт самому себе (иначе можно подделать accepted-инвайт
      // и самовольно войти в любое лобби).
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid != request.auth.uid;
      // Обновлять — отправитель или получатель
      allow update: if request.auth != null && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      // Удалять — отправитель или получатель
      allow delete: if request.auth != null && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
    }

    // ═══════════════════════════════════════════
    // КИБЕРСПОРТ — ТУРНИРЫ
    // ═══════════════════════════════════════════
    // Турниры шарятся по прямой ссылке (?cs=<id>). Поле isPublic=true разрешает
    // чтение без авторизации, чтобы зрители могли смотреть сетку по линку.
    // Писать может только создатель.
    match /tournaments/{tId} {
      // Публичный read для всех если isPublic == true. Иначе требуется auth
      // (чтобы залогиненный пользователь мог листать список).
      allow read: if (resource != null && resource.data.isPublic == true)
        || request.auth != null;

      // Создавать может только авторизованный, на своё имя, с обязательным isPublic
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.isPublic is bool;

      // Обновлять / удалять — только создатель. createdBy менять нельзя.
      allow update: if request.auth != null
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy;

      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      // Команды турнира
      match /teams/{teamId} {
        allow read: if (
          exists(/databases/$(database)/documents/tournaments/$(tId))
          && get(/databases/$(database)/documents/tournaments/$(tId)).data.isPublic == true
        ) || request.auth != null;
        allow write: if request.auth != null
          && exists(/databases/$(database)/documents/tournaments/$(tId))
          && get(/databases/$(database)/documents/tournaments/$(tId)).data.createdBy == request.auth.uid;
      }

      // Матчи турнира
      match /matches/{matchId} {
        allow read: if (
          exists(/databases/$(database)/documents/tournaments/$(tId))
          && get(/databases/$(database)/documents/tournaments/$(tId)).data.isPublic == true
        ) || request.auth != null;
        allow write: if request.auth != null
          && exists(/databases/$(database)/documents/tournaments/$(tId))
          && get(/databases/$(database)/documents/tournaments/$(tId)).data.createdBy == request.auth.uid;
      }
    }
  }
}
