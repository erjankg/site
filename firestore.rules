// Firestore Security Rules для Wild Rift Stats CMS
// Скопируй эти правила в Firebase Console → Firestore → Rules
//
// Путь: https://console.firebase.google.com/project/wildrift-stats-600c0/firestore/rules
//
// ═══════════════════════════════════════════
// Firebase Storage Rules (отдельно в Firebase Console → Storage → Rules):
//
// rules_version = '2';
// service firebase.storage {
//   match /b/{bucket}/o {
//     match /images/{allPaths=**} {
//       allow read: if true;
//       allow write: if request.auth != null
//         && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
//     }
//     match /items/{allPaths=**} {
//       allow read: if true;
//       allow write: if request.auth != null
//         && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
//     }
//     match /runes/{allPaths=**} {
//       allow read: if true;
//       allow write: if request.auth != null
//         && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
//     }
//   }
// }
// ═══════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Предметы — читать все, писать только админ
    match /items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Руны — читать все, писать только админ
    match /runes/{runeId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // История изменений — читать все, писать только админ
    match /changelog/{logId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Пользователи — существующие правила (не трогаем)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Чат — существующие правила
    match /globalChat/{msgId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Инфлюенсеры
    match /influencers/{infId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Винрейты — читать все, писать только админ
    match /winrates/{rankId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Патч-ноты — читать все, писать только админ
    match /patchnotes/{noteId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Конфигурация сайта — читать все, писать только админ
    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
